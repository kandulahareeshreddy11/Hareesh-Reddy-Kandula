{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "role": { "type": "string", "enum": ["student", "staff", "cleaning staff"], "description": "User role" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Issue": {
      "title": "Issue",
      "description": "Reported cleaning issue",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Issue ID" },
        "type": { "type": "string", "enum": ["dirty area", "water leakage", "garbage", "others"], "description": "Type of issue" },
        "description": { "type": "string", "description": "Description of the issue" },
        "location": { "type": "string", "description": "Location (block, room, etc.)" },
        "imageUrl": { "type": "string", "description": "Optional image URL" },
        "status": { "type": "string", "enum": ["Pending", "Completed"], "description": "Current status" },
        "reportedBy": { "type": "string", "description": "UID of the reporter" },
        "reportedByName": { "type": "string", "description": "Name of the reporter" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time reported" },
        "completionNote": { "type": "string", "description": "Optional note from cleaning staff" }
      },
      "required": ["type", "description", "location", "status", "reportedBy", "reportedByName", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/issues/{issueId}": {
      "schema": "Issue",
      "description": "Reported issues"
    }
  }
}
