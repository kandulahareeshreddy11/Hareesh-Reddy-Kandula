rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isCleaningStaff() {
      return isAuthenticated() && getUserRole() == 'cleaning staff';
    }
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "kandulahareeshreddy11@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, name, email, role
    //
    // Collection: issues
    // Fields: type, description, location, imageUrl, status, reportedBy, reportedByName, timestamp, completionNote

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(uid) && 
                    request.resource.data.role in ['student', 'staff', 'cleaning staff'];
      allow update: if isAuthenticated() && (isOwner(uid) || isAdmin());
    }

    match /issues/{issueId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.reportedBy == request.auth.uid &&
                    request.resource.data.status == 'Pending';
      allow update: if isAuthenticated() && (
                    (isCleaningStaff() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'completionNote'])) ||
                    isAdmin()
                  );
    }
  }
}
